<launch>
    <node name="clean_robot" pkg="clean_robot" type="clean_robot" output="screen">
        <param name="step" value="0.1"/>
        <param name="width" value="0.5"/>
        <param name="height" value="0.5"/>

        <param name="view_x" value="0.32"/>
        <param name="view_y" value="0.01"/>
        
        <param name="start_x_1" value="1.79"/>
        <param name="start_y_1" value="0.12"/>
        
        <param name="start_x_2" value="1.72"/>
        <param name="start_y_2" value="1.81"/>
        
        <param name="start_x_3" value="0.06"/>
        <param name="start_y_3" value="1.67"/>
    </node>
</launch>